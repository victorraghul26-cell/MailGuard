{
  "manifest_version": 3,
  "name": "Gmail Risk Analyzer",
  "version": "3.0",
  "permissions": ["activeTab"],
  "host_permissions": ["http://127.0.0.1:8000/*"],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}